# OpenFOAM build artifacts
Make/linux*
Make/darwin*
Make/win*

# Per-case generated headers (each cases/<name>/run.py emits these fresh)
Model.H
NumericsKernels.H
UpdateAuxVariables.H

# Python cache (test scripts under tests/)
__pycache__/
*.pyc

# OpenFOAM case runtime artifacts (cases/<name>/...)
cases/*/[0-9]*/
cases/*/constant/polyMesh/
cases/*/log.*
cases/*/postProcessing/
cases/*/processor*/
# Convergence/sweep cases generate per-(N, order) run subdirs.
cases/*/run_*/
# Coupling driver generates per-(scenario, scheme) work subdirs.
cases/*/work_*/
# Keep the case IC source under 0.orig and the system/ dictionaries.
!cases/*/0.orig/

# Coupled-case run outputs (regenerate via generate.py + run.sh)
cases/*/precice-run/
cases/*/precice-profiling/
cases/*/mono*/
cases/*/part*/
cases/*/results_*/
cases/*/*.snap/
cases/*/bin/
cases/sme_vof/demo/
cases/sme_vof/verify3/

# wmake artifacts of the function object
swePreciceCoupling/lnInclude/
swePreciceCoupling/Make/linux*

# Template mesh is regenerated by run.sh (blockMesh) in the run dir
cases/sme_vof/vof_template/constant/polyMesh/
