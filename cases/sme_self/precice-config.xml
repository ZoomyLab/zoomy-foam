<?xml version="1.0" encoding="UTF-8" ?>
<precice-configuration>
  <data:scalar name="b_1"/>
  <data:scalar name="h_1"/>
  <data:scalar name="u_1"/>
  <data:scalar name="v_1"/>
  <data:scalar name="w_1"/>
  <data:scalar name="p_1"/>
  <data:scalar name="b_2"/>
  <data:scalar name="h_2"/>
  <data:scalar name="u_2"/>
  <data:scalar name="v_2"/>
  <data:scalar name="w_2"/>
  <data:scalar name="p_2"/>

  <mesh name="MeshA" dimensions="3">
    <use-data name="b_1"/>
    <use-data name="h_1"/>
    <use-data name="u_1"/>
    <use-data name="v_1"/>
    <use-data name="w_1"/>
    <use-data name="p_1"/>
    <use-data name="b_2"/>
    <use-data name="h_2"/>
    <use-data name="u_2"/>
    <use-data name="v_2"/>
    <use-data name="w_2"/>
    <use-data name="p_2"/>
  </mesh>
  <mesh name="MeshB" dimensions="3">
    <use-data name="b_1"/>
    <use-data name="h_1"/>
    <use-data name="u_1"/>
    <use-data name="v_1"/>
    <use-data name="w_1"/>
    <use-data name="p_1"/>
    <use-data name="b_2"/>
    <use-data name="h_2"/>
    <use-data name="u_2"/>
    <use-data name="v_2"/>
    <use-data name="w_2"/>
    <use-data name="p_2"/>
  </mesh>

  <participant name="SmeA">
      <provide-mesh name="MeshA"/>
      <receive-mesh name="MeshB" from="SmeB"/>
      <write-data name="b_1" mesh="MeshA"/>
      <write-data name="h_1" mesh="MeshA"/>
      <write-data name="u_1" mesh="MeshA"/>
      <write-data name="v_1" mesh="MeshA"/>
      <write-data name="w_1" mesh="MeshA"/>
      <write-data name="p_1" mesh="MeshA"/>
      <read-data name="b_2" mesh="MeshA"/>
      <read-data name="h_2" mesh="MeshA"/>
      <read-data name="u_2" mesh="MeshA"/>
      <read-data name="v_2" mesh="MeshA"/>
      <read-data name="w_2" mesh="MeshA"/>
      <read-data name="p_2" mesh="MeshA"/>
      <mapping:nearest-neighbor direction="read" from="MeshB" to="MeshA" constraint="consistent"/>
  </participant>

  <participant name="SmeB">
      <provide-mesh name="MeshB"/>
      <receive-mesh name="MeshA" from="SmeA"/>
      <write-data name="b_2" mesh="MeshB"/>
      <write-data name="h_2" mesh="MeshB"/>
      <write-data name="u_2" mesh="MeshB"/>
      <write-data name="v_2" mesh="MeshB"/>
      <write-data name="w_2" mesh="MeshB"/>
      <write-data name="p_2" mesh="MeshB"/>
      <read-data name="b_1" mesh="MeshB"/>
      <read-data name="h_1" mesh="MeshB"/>
      <read-data name="u_1" mesh="MeshB"/>
      <read-data name="v_1" mesh="MeshB"/>
      <read-data name="w_1" mesh="MeshB"/>
      <read-data name="p_1" mesh="MeshB"/>
      <mapping:nearest-neighbor direction="read" from="MeshA" to="MeshB" constraint="consistent"/>
  </participant>

  <m2n:sockets acceptor="SmeA" connector="SmeB" exchange-directory="/Users/adam-obbpb5az1dhsjzf/git/Zoomy/library/zoomy_foam/cases/sme_self"/>

  <coupling-scheme:parallel-explicit>
    <participants first="SmeA" second="SmeB"/>
    <max-time value="1.0"/>
    <time-window-size value="0.005"/>
    <exchange data="b_1" mesh="MeshA" from="SmeA" to="SmeB" initialize="true"/>
    <exchange data="h_1" mesh="MeshA" from="SmeA" to="SmeB" initialize="true"/>
    <exchange data="u_1" mesh="MeshA" from="SmeA" to="SmeB" initialize="true"/>
    <exchange data="v_1" mesh="MeshA" from="SmeA" to="SmeB" initialize="true"/>
    <exchange data="w_1" mesh="MeshA" from="SmeA" to="SmeB" initialize="true"/>
    <exchange data="p_1" mesh="MeshA" from="SmeA" to="SmeB" initialize="true"/>
    <exchange data="b_2" mesh="MeshB" from="SmeB" to="SmeA" initialize="true"/>
    <exchange data="h_2" mesh="MeshB" from="SmeB" to="SmeA" initialize="true"/>
    <exchange data="u_2" mesh="MeshB" from="SmeB" to="SmeA" initialize="true"/>
    <exchange data="v_2" mesh="MeshB" from="SmeB" to="SmeA" initialize="true"/>
    <exchange data="w_2" mesh="MeshB" from="SmeB" to="SmeA" initialize="true"/>
    <exchange data="p_2" mesh="MeshB" from="SmeB" to="SmeA" initialize="true"/>
  </coupling-scheme:parallel-explicit>
</precice-configuration>
