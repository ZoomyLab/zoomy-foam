<?xml version="1.0" encoding="UTF-8" ?>
<precice-configuration>
  <data:scalar name="b_1"/>
  <data:scalar name="h_1"/>
  <data:scalar name="u_1"/>
  <data:scalar name="v_1"/>
  <data:scalar name="w_1"/>
  <data:scalar name="p_1"/>
  <data:scalar name="b_2"/>
  <data:scalar name="h_2"/>
  <data:scalar name="u_2"/>
  <data:scalar name="v_2"/>
  <data:scalar name="w_2"/>
  <data:scalar name="p_2"/>

  <mesh name="Mesh0" dimensions="3">
    <use-data name="b_1"/>
    <use-data name="h_1"/>
    <use-data name="u_1"/>
    <use-data name="v_1"/>
    <use-data name="w_1"/>
    <use-data name="p_1"/>
    <use-data name="b_2"/>
    <use-data name="h_2"/>
    <use-data name="u_2"/>
    <use-data name="v_2"/>
    <use-data name="w_2"/>
    <use-data name="p_2"/>
  </mesh>
  <mesh name="Mesh1" dimensions="3">
    <use-data name="b_1"/>
    <use-data name="h_1"/>
    <use-data name="u_1"/>
    <use-data name="v_1"/>
    <use-data name="w_1"/>
    <use-data name="p_1"/>
    <use-data name="b_2"/>
    <use-data name="h_2"/>
    <use-data name="u_2"/>
    <use-data name="v_2"/>
    <use-data name="w_2"/>
    <use-data name="p_2"/>
  </mesh>

  <participant name="Sme0">
      <provide-mesh name="Mesh0"/>
      <receive-mesh name="Mesh1" from="Sme1"/>
      <write-data name="b_1" mesh="Mesh0"/>
      <write-data name="h_1" mesh="Mesh0"/>
      <write-data name="u_1" mesh="Mesh0"/>
      <write-data name="v_1" mesh="Mesh0"/>
      <write-data name="w_1" mesh="Mesh0"/>
      <write-data name="p_1" mesh="Mesh0"/>
      <read-data name="b_2" mesh="Mesh0"/>
      <read-data name="h_2" mesh="Mesh0"/>
      <read-data name="u_2" mesh="Mesh0"/>
      <read-data name="v_2" mesh="Mesh0"/>
      <read-data name="w_2" mesh="Mesh0"/>
      <read-data name="p_2" mesh="Mesh0"/>
      <mapping:nearest-neighbor direction="read" from="Mesh1" to="Mesh0" constraint="consistent"/>
  </participant>

  <participant name="Sme1">
      <provide-mesh name="Mesh1"/>
      <receive-mesh name="Mesh0" from="Sme0"/>
      <write-data name="b_2" mesh="Mesh1"/>
      <write-data name="h_2" mesh="Mesh1"/>
      <write-data name="u_2" mesh="Mesh1"/>
      <write-data name="v_2" mesh="Mesh1"/>
      <write-data name="w_2" mesh="Mesh1"/>
      <write-data name="p_2" mesh="Mesh1"/>
      <read-data name="b_1" mesh="Mesh1"/>
      <read-data name="h_1" mesh="Mesh1"/>
      <read-data name="u_1" mesh="Mesh1"/>
      <read-data name="v_1" mesh="Mesh1"/>
      <read-data name="w_1" mesh="Mesh1"/>
      <read-data name="p_1" mesh="Mesh1"/>
      <mapping:nearest-neighbor direction="read" from="Mesh0" to="Mesh1" constraint="consistent"/>
  </participant>

  <m2n:sockets acceptor="Sme0" connector="Sme1" exchange-directory="/Users/adam-obbpb5az1dhsjzf/git/Zoomy/library/zoomy_foam/cases/sme0_sme1"/>

  <coupling-scheme:parallel-implicit>
    <participants first="Sme0" second="Sme1"/>
    <max-time value="1.0"/>
    <time-window-size value="0.0005"/>
    <max-iterations value="50"/>
    <relative-convergence-measure data="h_1" mesh="Mesh0" limit="1e-6"/>
    <relative-convergence-measure data="h_2" mesh="Mesh1" limit="1e-6"/>
    <exchange data="b_1" mesh="Mesh0" from="Sme0" to="Sme1"/>
    <exchange data="h_1" mesh="Mesh0" from="Sme0" to="Sme1"/>
    <exchange data="u_1" mesh="Mesh0" from="Sme0" to="Sme1"/>
    <exchange data="v_1" mesh="Mesh0" from="Sme0" to="Sme1"/>
    <exchange data="w_1" mesh="Mesh0" from="Sme0" to="Sme1"/>
    <exchange data="p_1" mesh="Mesh0" from="Sme0" to="Sme1"/>
    <exchange data="b_2" mesh="Mesh1" from="Sme1" to="Sme0"/>
    <exchange data="h_2" mesh="Mesh1" from="Sme1" to="Sme0"/>
    <exchange data="u_2" mesh="Mesh1" from="Sme1" to="Sme0"/>
    <exchange data="v_2" mesh="Mesh1" from="Sme1" to="Sme0"/>
    <exchange data="w_2" mesh="Mesh1" from="Sme1" to="Sme0"/>
    <exchange data="p_2" mesh="Mesh1" from="Sme1" to="Sme0"/>
    <acceleration:constant><relaxation value="0.5"/></acceleration:constant>
  </coupling-scheme:parallel-implicit>
</precice-configuration>
