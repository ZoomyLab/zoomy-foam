FoamFile
{
    format      ascii;
    class       dictionary;
    object      blockMeshDict;
}

convertToMeters 1;

xmin    0;   xmax   10;
ymin    0;   ymax    1;
zmin    0;   zmax    1;
nx    200;

vertices
(
    ($xmin $ymin $zmin)
    ($xmax $ymin $zmin)
    ($xmax $ymax $zmin)
    ($xmin $ymax $zmin)
    ($xmin $ymin $zmax)
    ($xmax $ymin $zmax)
    ($xmax $ymax $zmax)
    ($xmin $ymax $zmax)
);

blocks
(
    hex (0 1 2 3 4 5 6 7) ($nx 1 1) simpleGrading (1 1 1)
);

edges ();

boundary
(
    inflow       { type patch; faces ((0 4 7 3)); }
    outflow      { type patch; faces ((1 2 6 5)); }
    sides        { type empty; faces ((0 1 5 4) (3 7 6 2)); }
    topAndBottom { type empty; faces ((0 3 2 1) (4 5 6 7)); }
);

mergePatchPairs ();
