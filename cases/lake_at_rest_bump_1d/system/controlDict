FoamFile
{
    format      ascii;
    class       dictionary;
    object      controlDict;
}

application     zoomyFoam;
startFrom       startTime;
startTime       0;
stopAt          endTime;
endTime         2.0;
deltaT          0.001;
writeControl    adjustableRunTime;
writeInterval   0.5;
purgeWrite      0;
writeFormat     ascii;
writePrecision  12;
timeFormat      general;
runTimeModifiable true;
adjustTimeStep  no;
maxCo           0.4;

// HR (Audusse) formulation is WB at 1st order; at 2nd order it needs the
// bed held at cell centres (the b_star = max(b_L,b_R) logic), which the
// solver no longer hand-skips. For 2nd-order WB use the Malaga formulation
// (cases/lake_at_rest_bump_malaga_1d) — equilibrium viscosity, no skip.
reconstructionOrder    1;
