FoamFile
{
    format      ascii;
    class       dictionary;
    object      controlDict;
}

application     zoomyFoam;
startFrom       startTime;
startTime       0;
stopAt          endTime;
endTime         2.0;
deltaT          0.001;
writeControl    adjustableRunTime;
writeInterval   0.5;
purgeWrite      0;
writeFormat     ascii;
writePrecision  12;
timeFormat      general;
runTimeModifiable true;
adjustTimeStep  no;
maxCo           0.4;

// Phase 5: 1 = forward Euler + 1st-order space, 2 = SSP-RK2 + W-reconstruction
reconstructionOrder    2;
